# --- Stage 1: Build Phase ---
FROM node:20-alpine AS builder
WORKDIR /app

# Copy dependency catalogs
COPY package*.json ./
RUN npm ci --silent

# Copy code modules
COPY . .

# Compile application bundle
RUN npm run build

# --- Stage 2: Service Phase ---
FROM nginx:1.25-alpine
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy secure reverse proxy configurations
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
