# ==========================================
# Sferium Homes - Environment Configuration Example
# Copy this file to .env and configure your values.
# ==========================================

# 1. API и Внешние Пути (Frontend & Connection)
# Адрес бэкенд API (например, https://sferium.homes или http://localhost:8000 в локальной среде)
VITE_API_BASE_URL=https://sferium.homes

# Идентификатор приложения ВКонтакте для авторизации во встроенном VK-плеере
VITE_VK_CLIENT_ID=51786574

# 2. База Данных PostgreSQL (Backend)
# Полная строка подключения к базе данных PostgreSQL (используется SQLAlchemy AsyncPG)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sferium_chat

# Отдельные параметры PostgreSQL (если требуются)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sferium_chat
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# 3. Кэширование Redis (Backend)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 4. Безопасность и Сессии (JWT)
JWT_SECRET=sferium_super_secure_secret_hash_key_cto_level_2026

# 5. Ключ API Google Gemini (AI Studio)
# Требуется для функций ИИ в серверных роутах
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
